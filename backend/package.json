{
  "name": "chatprex-backend",
  "version": "1.0.0",
  "description": "Backend para ChatPrex CRM",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "esbuild src/**/*.ts --outdir=dist --platform=node --format=cjs",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "openai": "^6.36.0",
    "pg": "^8.13.0",
    "socket.io": "^4.7.5",
    "ws": "^8.18.0",
    "twilio": "^5.2.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.12.11",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.11",
    "esbuild": "^0.20.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
